{
  "annotations": {"list": []},
  "description": "Hook guardrail evaluations — verdict funnel, severity breakdown, runtime alerts, and inspect latency. All panels source from defenseclaw_inspect_evaluations_total which fires on every hook connector.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {"title": "Overview",           "type": "link", "url": "/d/defenseclaw-overview?${__url_time_range}",                                  "icon": "external link", "targetBlank": false},
    {"title": "Hook Connectors",    "type": "link", "url": "/d/defenseclaw-connectors?${__url_time_range}",                                "icon": "external link", "targetBlank": false},
    {"title": "Connector detail",   "type": "link", "url": "/d/defenseclaw-connector-detail?${__url_time_range}&${connector:queryparam}",  "icon": "external link", "targetBlank": false},
    {"title": "HITL",               "type": "link", "url": "/d/defenseclaw-hitl?${__url_time_range}",                                      "icon": "external link", "targetBlank": false},
    {"title": "Findings",           "type": "link", "url": "/d/defenseclaw-findings?${__url_time_range}&${severity:queryparam}",           "icon": "external link", "targetBlank": false},
    {"title": "Policy decisions",   "type": "link", "url": "/d/defenseclaw-policy-decisions?${__url_time_range}",                          "icon": "external link", "targetBlank": false},
    {"title": "Proxy & LLM Guard",  "type": "link", "url": "/d/defenseclaw-traffic?${__url_time_range}",                                   "icon": "external link", "targetBlank": false}
  ],
  "templating": {
    "list": [
      {
        "name": "stage",
        "label": "Hook event",
        "description": "Filter by hook event type (tool label on inspect evaluations)",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
        "definition": "label_values(defenseclaw_inspect_evaluations_total, tool)",
        "query": {"query": "label_values(defenseclaw_inspect_evaluations_total, tool)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": ["All"], "value": ["$__all"], "selected": true},
        "skipUrlSync": false,
        "hide": 0
      },
      {
        "name": "action",
        "label": "Verdict action",
        "type": "custom",
        "query": "allow,warn,alert,confirm,block",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": ["All"], "value": ["$__all"], "selected": true},
        "options": [
          {"text": "All", "value": "$__all", "selected": true},
          {"text": "allow", "value": "allow"},
          {"text": "warn", "value": "warn"},
          {"text": "alert", "value": "alert"},
          {"text": "confirm", "value": "confirm"},
          {"text": "block", "value": "block"}
        ],
        "skipUrlSync": false,
        "hide": 0
      },
      {
        "name": "severity",
        "label": "Severity",
        "type": "custom",
        "query": "CRITICAL,HIGH,MEDIUM,LOW,INFO,NONE",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": ["All"], "value": ["$__all"], "selected": true},
        "options": [
          {"text": "All", "value": "$__all", "selected": true},
          {"text": "CRITICAL", "value": "CRITICAL"},
          {"text": "HIGH", "value": "HIGH"},
          {"text": "MEDIUM", "value": "MEDIUM"},
          {"text": "LOW", "value": "LOW"},
          {"text": "INFO", "value": "INFO"},
          {"text": "NONE", "value": "NONE"}
        ],
        "skipUrlSync": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {"type": "row", "title": "Verdict KPIs", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "stat",
      "title": "Verdicts (1h)",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(increase(defenseclaw_inspect_evaluations_total{tool=~\"$stage\", action=~\"$action\", severity=~\"$severity\"}[1h])) or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },
    {
      "type": "stat",
      "title": "Block rate (1h)",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_inspect_evaluations_total{action=\"block\"}[1h])) / clamp_min(sum(rate(defenseclaw_inspect_evaluations_total[1h])), 0.0001) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.05}, {"color": "red", "value": 0.25}]}}}
    },
    {
      "type": "stat",
      "title": "Confirm rate (1h)",
      "description": "Fraction of verdicts requesting human approval.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_inspect_evaluations_total{action=\"confirm\"}[1h])) / clamp_min(sum(rate(defenseclaw_inspect_evaluations_total[1h])), 0.0001) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "type": "stat",
      "title": "Warn+Alert rate (1h)",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_inspect_evaluations_total{action=~\"warn|alert\"}[1h])) / clamp_min(sum(rate(defenseclaw_inspect_evaluations_total[1h])), 0.0001) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "type": "stat",
      "title": "Inspect latency p95 (5m)",
      "description": "95th percentile guardrail evaluation latency across all hook events.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(defenseclaw_inspect_latency_milliseconds_bucket[5m])) by (le)) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}}}
    },
    {
      "type": "stat",
      "title": "Alerts / min (5m)",
      "description": "Runtime security alerts fired in the last 5 minutes.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_alert_count_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 10}]}}}
    },

    {"type": "row", "title": "Verdict funnel (hook event x action)", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "bargauge",
      "title": "Funnel: hook event -> action (1h)",
      "description": "Total verdicts (1h) for each (hook event, action) pair. Long bars on action=block show where traffic is being denied.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 8},
      "targets": [{"expr": "sort_desc(sum by (tool, action) (increase(defenseclaw_inspect_evaluations_total{tool=~\"$stage\", action=~\"$action\", severity=~\"$severity\"}[1h])))", "instant": true, "format": "time_series", "legendFormat": "{{tool}} -> {{action}}", "refId": "A"}],
      "options": {"displayMode": "gradient", "valueMode": "color", "showUnfilled": true, "orientation": "horizontal"}
    },
    {
      "type": "timeseries",
      "title": "Action mix over time (stacked)",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total{tool=~\"$stage\", severity=~\"$severity\"}[$__rate_interval]))", "legendFormat": "{{action}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 25}}}
    },
    {
      "type": "timeseries",
      "title": "Verdicts by hook event (stacked)",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (tool) (rate(defenseclaw_inspect_evaluations_total{action=~\"$action\", severity=~\"$severity\"}[$__rate_interval]))", "legendFormat": "{{tool}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 25}}}
    },

    {"type": "row", "title": "Severity breakdown", "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Verdicts by severity",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 23, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (severity) (rate(defenseclaw_inspect_evaluations_total{tool=~\"$stage\", action=~\"$action\"}[$__rate_interval]))", "legendFormat": "{{severity}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 25}}}
    },
    {
      "type": "timeseries",
      "title": "Non-allow evaluations by hook event",
      "description": "Evaluations that resulted in alert/block/confirm, broken by which hook event triggered them.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 23, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (tool, action) (rate(defenseclaw_inspect_evaluations_total{action!=\"allow\"}[$__rate_interval]))", "legendFormat": "{{tool}} -> {{action}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 25}}}
    },

    {"type": "row", "title": "Runtime alerts", "gridPos": {"x": 0, "y": 31, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Alerts / sec by type x severity",
      "description": "Runtime alerts from all detection engines (local-pattern, local-guardrail, ai-defense, opa-policy, codeguard).",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (alert_type, alert_severity) (rate(defenseclaw_alert_count_total[$__rate_interval]))", "legendFormat": "{{alert_type}} [{{alert_severity}}]", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"fillOpacity": 20}}}
    },
    {
      "type": "timeseries",
      "title": "Inspect latency p50/p95/p99 by hook event",
      "description": "Per-hook-event guardrail evaluation latency quantiles.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le, tool) (rate(defenseclaw_inspect_latency_milliseconds_bucket[$__rate_interval])))", "legendFormat": "{{tool}} p50", "refId": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le, tool) (rate(defenseclaw_inspect_latency_milliseconds_bucket[$__rate_interval])))", "legendFormat": "{{tool}} p95", "refId": "p95"},
        {"expr": "histogram_quantile(0.99, sum by (le, tool) (rate(defenseclaw_inspect_latency_milliseconds_bucket[$__rate_interval])))", "legendFormat": "{{tool}} p99", "refId": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },

    {"type": "row", "title": "Connector breakdown", "gridPos": {"x": 0, "y": 40, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Evaluations / sec by connector",
      "description": "Guardrail evaluations split by connector prefix (claudecode, codex, hermes, cursor, windsurf, geminicli, copilot).",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 41, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (tool) (rate(defenseclaw_inspect_evaluations_total{action!=\"allow\"}[$__rate_interval]))", "legendFormat": "{{tool}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 20}}}
    },
    {
      "type": "table",
      "title": "Per-connector verdict summary (1h)",
      "description": "Snapshot: total verdicts, blocks, alerts, and confirm per connector hook event in the last hour.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 41, "w": 12, "h": 8},
      "targets": [
        {"refId": "TOTAL", "instant": true, "format": "table", "expr": "sum by (tool) (increase(defenseclaw_inspect_evaluations_total[1h]))"},
        {"refId": "BLOCKS", "instant": true, "format": "table", "expr": "sum by (tool) (increase(defenseclaw_inspect_evaluations_total{action=\"block\"}[1h]))"},
        {"refId": "ALERTS", "instant": true, "format": "table", "expr": "sum by (tool) (increase(defenseclaw_inspect_evaluations_total{action=\"alert\"}[1h]))"},
        {"refId": "CONFIRM", "instant": true, "format": "table", "expr": "sum by (tool) (increase(defenseclaw_inspect_evaluations_total{action=\"confirm\"}[1h]))"}
      ],
      "transformations": [
        {"id": "renameByRegex", "options": {"regexp": "Value #(\\w+)", "renamePattern": "$1"}},
        {"id": "merge"},
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true}, "renameByName": {"tool": "hook event", "TOTAL": "total/1h", "BLOCKS": "blocks/1h", "ALERTS": "alerts/1h", "CONFIRM": "confirms/1h"}}}
      ]
    },

    {"type": "row", "title": "Recent verdict events (Loki)", "gridPos": {"x": 0, "y": 49, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "logs",
      "title": "Recent guardrail events",
      "description": "Gateway log records for verdict and scan events.",
      "datasource": {"type": "loki", "uid": "defenseclaw-loki"},
      "gridPos": {"x": 0, "y": 50, "w": 24, "h": 12},
      "timeFrom": "1h",
      "targets": [{"expr": "{service_namespace=\"ai-governance\"} | json | __error__=\"\" | event_type=~\"verdict|scan|scan_finding|error\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true}
    }
  ],
  "preload": false,
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["defenseclaw", "security", "guardrail", "hook"],
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "DefenseClaw — Guardrail Evaluations",
  "uid": "defenseclaw-security",
  "version": 4,
  "weekStart": ""
}
