{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {"title": "Overview",         "type": "link", "url": "/d/defenseclaw-overview?${__url_time_range}",                                                                                       "icon": "external link", "targetBlank": false},
    {"title": "Connector detail", "type": "link", "url": "/d/defenseclaw-connector-detail?${__url_time_range}&${connector:queryparam}",                                                       "icon": "external link", "targetBlank": false},
    {"title": "Guardrail Evals",  "type": "link", "url": "/d/defenseclaw-security?${__url_time_range}&${stage:queryparam}&${action:queryparam}&${severity:queryparam}&${connector:queryparam}", "icon": "external link", "targetBlank": false},
    {"title": "HITL",             "type": "link", "url": "/d/defenseclaw-hitl?${__url_time_range}&${connector:queryparam}",                                                                   "icon": "external link", "targetBlank": false},
    {"title": "Findings",         "type": "link", "url": "/d/defenseclaw-findings?${__url_time_range}&${severity:queryparam}",                                                                 "icon": "external link", "targetBlank": false},
    {"title": "Agent identity",   "type": "link", "url": "/d/defenseclaw-agent-identity?${__url_time_range}&${connector:queryparam}",                                                          "icon": "external link", "targetBlank": false},
    {"title": "Policy decisions", "type": "link", "url": "/d/defenseclaw-policy-decisions?${__url_time_range}",                                                                                "icon": "external link", "targetBlank": false}
  ],
  "templating": {
    "list": [
      {
        "name": "connector",
        "label": "Connector",
        "description": "Filter panels by connector name. Sourced from defenseclaw_connector_hook_invocations_total{connector} so hook-only connectors (cursor, hermes, copilot, geminicli, windsurf) show up too — defenseclaw_otel_ingest_records_total only carries connectors that push native OTLP and would silently exclude every hook-only connector.",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
        "definition": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
        "query": {"query": "label_values(defenseclaw_connector_hook_invocations_total, connector)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": ["All"], "value": ["$__all"], "selected": true},
        "skipUrlSync": false,
        "hide": 0
      },
      {
        "name": "stage",
        "label": "Verdict stage",
        "type": "custom",
        "query": "regex,judge,cisco_ai_defense,opa,final,session_message,multi_turn,block_list,approval",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": ["All"], "value": ["$__all"], "selected": true},
        "options": [
          {"text": "All", "value": "$__all", "selected": true},
          {"text": "regex", "value": "regex"},
          {"text": "judge", "value": "judge"},
          {"text": "cisco_ai_defense", "value": "cisco_ai_defense"},
          {"text": "opa", "value": "opa"},
          {"text": "final", "value": "final"},
          {"text": "session_message", "value": "session_message"},
          {"text": "multi_turn", "value": "multi_turn"},
          {"text": "block_list", "value": "block_list"},
          {"text": "approval", "value": "approval"}
        ],
        "skipUrlSync": false,
        "hide": 2
      },
      {
        "name": "action",
        "label": "Verdict action",
        "type": "custom",
        "query": "allow,warn,alert,confirm,block",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": ["All"], "value": ["$__all"], "selected": true},
        "options": [
          {"text": "All", "value": "$__all", "selected": true},
          {"text": "allow", "value": "allow"},
          {"text": "warn", "value": "warn"},
          {"text": "alert", "value": "alert"},
          {"text": "confirm", "value": "confirm"},
          {"text": "block", "value": "block"}
        ],
        "skipUrlSync": false,
        "hide": 2
      },
      {
        "name": "severity",
        "label": "Severity",
        "type": "custom",
        "query": "CRITICAL,HIGH,MEDIUM,LOW,INFO,NONE",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": ["All"], "value": ["$__all"], "selected": true},
        "options": [
          {"text": "All", "value": "$__all", "selected": true},
          {"text": "CRITICAL", "value": "CRITICAL"},
          {"text": "HIGH", "value": "HIGH"},
          {"text": "MEDIUM", "value": "MEDIUM"},
          {"text": "LOW", "value": "LOW"},
          {"text": "INFO", "value": "INFO"},
          {"text": "NONE", "value": "NONE"}
        ],
        "skipUrlSync": false,
        "hide": 2
      }
    ]
  },
  "panels": [
    {"type": "row", "title": "Cross-connector summary", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "stat",
      "title": "Active connectors (5m)",
      "description": "Distinct sources that have emitted any OTLP record in the last 5 minutes.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "count(group by (source) (rate(defenseclaw_otel_ingest_records_total{source=~\"$connector\"}[5m]) > 0)) or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "OTLP records / min",
      "description": "Sum of all inbound OTLP records (logs + metrics + traces) in the last 5 minutes.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_otel_ingest_records_total{source=~\"$connector\"}[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Hook invocations / min",
      "description": "Hook scripts that reached the gateway, scoped to $connector.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_connector_hook_invocations_total{connector=~\"$connector\"}[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Evaluations / min",
      "description": "Total guardrail evaluations (all actions) in the last 5 minutes.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_inspect_evaluations_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Blocks / min",
      "description": "Guardrail evaluations with action=block across all connectors.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_inspect_evaluations_total{action=\"block\"}[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 10}]}}}
    },
    {
      "type": "stat",
      "title": "GenAI tokens / min",
      "description": "Total GenAI token throughput (input + output) across all connectors.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(gen_ai_client_token_usage_sum[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },

    {"type": "row", "title": "Per-connector comparison", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "table",
      "title": "Per-connector traffic (5m rates, /min)",
      "description": "One row per connector. Combines OTLP ingest records/min, hook invocations/min, and GenAI tokens/min. Click a connector cell to drill into Connector Detail.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 6, "w": 24, "h": 10},
      "targets": [
        {"refId": "INGEST", "instant": true, "format": "table", "expr": "sum by (source) (rate(defenseclaw_otel_ingest_records_total{source=~\"$connector\"}[5m])) * 60"},
        {"refId": "HOOKS",  "instant": true, "format": "table", "expr": "sum by (connector) (rate(defenseclaw_connector_hook_invocations_total{connector=~\"$connector\"}[5m])) * 60"},
        {"refId": "TOKENS", "instant": true, "format": "table", "expr": "sum by (gen_ai_agent_name) (rate(gen_ai_client_token_usage_sum[5m])) * 60"}
      ],
      "transformations": [
        {"id": "renameByRegex", "options": {"regexp": "Value #(\\w+)", "renamePattern": "$1"}},
        {"id": "merge"},
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true, "service": true, "service_name": true, "service_version": true, "exported_job": true, "defenseclaw_claw_home_dir": true, "defenseclaw_claw_mode": true, "defenseclaw_device_id": true, "defenseclaw_gateway_host": true, "defenseclaw_gateway_port": true, "defenseclaw_instance_id": true, "defenseclaw_preset": true, "defenseclaw_preset_name": true, "deployment_environment": true, "host_arch": true, "host_name": true, "os_type": true}, "renameByName": {"source": "connector", "connector": "connector", "gen_ai_agent_name": "connector", "INGEST": "records/min", "HOOKS": "hooks/min", "TOKENS": "tokens/min"}, "indexByName": {"connector": 0, "records/min": 1, "hooks/min": 2, "tokens/min": 3}}}
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "left", "cellOptions": {"type": "auto"}},
          "thresholds": {"mode": "absolute", "steps": [{"color": "transparent", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "connector"}, "properties": [{"id": "links", "value": [{"title": "Open Connector Detail", "url": "/d/defenseclaw-connector-detail?${__url_time_range}&var-connector=${__value.text}", "targetBlank": false}]}]}
        ]
      }
    },

    {"type": "row", "title": "OTLP ingest by connector", "gridPos": {"x": 0, "y": 16, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Records / sec by source x signal",
      "description": "Leaf records (logRecords / dataPoints / spans) per second grouped by connector source and signal type.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 17, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (source, signal) (rate(defenseclaw_otel_ingest_records_total{source=~\"$connector\"}[$__rate_interval]))", "legendFormat": "{{source}} / {{signal}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Bytes / sec by source x signal",
      "description": "Inbound body size per connector per signal. Spikes correlate with verbose tool-use prompts or large completions.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 17, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (source, signal) (rate(defenseclaw_otel_ingest_bytes_total{source=~\"$connector\"}[$__rate_interval]))", "legendFormat": "{{source}} / {{signal}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },

    {"type": "row", "title": "Hook invocations (drift detection)", "gridPos": {"x": 0, "y": 25, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Hook invocations / sec by connector x result",
      "description": "Hook requests by connector and result (ok/degraded/rejected/unknown). Sustained drift between hook rate and OTel record rate hints at a stale or misconfigured hook.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 26, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (connector, result) (rate(defenseclaw_connector_hook_invocations_total{connector=~\"$connector\"}[$__rate_interval]))", "legendFormat": "{{connector}} / {{result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Hook invocations / sec by event type",
      "description": "Hook invocations broken out by event_type (preToolUse, postToolUse, stop, etc). Shows which hook lifecycle events are firing.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 26, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (event_type) (rate(defenseclaw_connector_hook_invocations_total{connector=~\"$connector\"}[$__rate_interval]))", "legendFormat": "{{event_type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },

    {"type": "row", "title": "GenAI tokens + LLM duration", "gridPos": {"x": 0, "y": 34, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Tokens / sec by connector x direction",
      "description": "OTel GenAI semconv counter (gen_ai.client.token.usage) grouped by agent name and token type (input/output).",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 35, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (gen_ai_agent_name, gen_ai_token_type) (rate(gen_ai_client_token_usage_sum[$__rate_interval]))", "legendFormat": "{{gen_ai_agent_name}} / {{gen_ai_token_type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "LLM operation duration p95 by connector",
      "description": "gen_ai.client.operation.duration histogram p95 grouped by gen_ai_agent_name.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 35, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, gen_ai_agent_name) (rate(gen_ai_client_operation_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{gen_ai_agent_name}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },

    {"type": "row", "title": "Guardrail evaluations", "gridPos": {"x": 0, "y": 43, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Evaluations / sec by action",
      "description": "Guardrail evaluation outcomes (allow/alert/block/confirm) from hook inspect pipeline.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 44, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total[$__rate_interval]))", "legendFormat": "{{action}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}}
    },
    {
      "type": "timeseries",
      "title": "Evaluations / sec by severity",
      "description": "Guardrail evaluations by severity (CRITICAL/HIGH/MEDIUM/LOW/NONE). Non-NONE means a rule matched.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 8, "y": 44, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (severity) (rate(defenseclaw_inspect_evaluations_total{severity!=\"NONE\"}[$__rate_interval]))", "legendFormat": "{{severity}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}}
    },
    {
      "type": "timeseries",
      "title": "Evaluations / sec by hook event",
      "description": "Which hook lifecycle events are triggering guardrail evaluations.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 16, "y": 44, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (tool) (rate(defenseclaw_inspect_evaluations_total{action!=\"allow\"}[$__rate_interval]))", "legendFormat": "{{tool}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}}
    },

    {"type": "row", "title": "Gateway event flow", "gridPos": {"x": 0, "y": 52, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Events / sec by type",
      "description": "All structured gateway events (tool_invocation, lifecycle, egress, llm_prompt, llm_response, verdict, judge, error, scan, ai_discovery). This is the definitive view of what DefenseClaw is processing across all connectors.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 53, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (event_type) (rate(defenseclaw_gateway_events_emitted_total[$__rate_interval]))", "legendFormat": "{{event_type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 20}}}
    },
    {
      "type": "timeseries",
      "title": "Audit events / sec by action",
      "description": "Audit records written per second, by action type (claude-code-hook, otel.ingest.logs, otel.ingest.metrics). Shows the total governance pipeline throughput.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 53, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (action) (rate(defenseclaw_audit_events_total[$__rate_interval]))", "legendFormat": "{{action}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 20}}}
    },

    {"type": "row", "title": "Connector health", "gridPos": {"x": 0, "y": 61, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "table",
      "title": "Codex notify by type + status (5m)",
      "description": "Codex notify-bridge events. result=malformed means the bridge sent a body that did not parse as JSON.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 53, "w": 12, "h": 8},
      "targets": [{"expr": "sort_desc(sum by (type, status, result) (increase(defenseclaw_codex_notify_total[5m])))", "instant": true, "format": "table", "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true, "service": true, "service_name": true, "service_version": true}, "renameByName": {"Value": "events/5m"}}}]
    },
    {
      "type": "table",
      "title": "Quietest connectors (silence sec)",
      "description": "Seconds since the gateway last accepted an OTel batch. >600s triggers DefenseClawConnectorTelemetrySilent.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 53, "w": 12, "h": 8},
      "targets": [{"expr": "sort_desc(time() - max by (source) (defenseclaw_otel_ingest_last_seen_ts_seconds{source=~\"$connector\"}))", "instant": true, "format": "table", "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true, "service": true, "service_name": true, "service_version": true}, "renameByName": {"Value": "silence (s)", "source": "connector"}}}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 60}, {"color": "red", "value": 600}]}}, "overrides": [{"matcher": {"id": "byName", "options": "connector"}, "properties": [{"id": "links", "value": [{"title": "Open Connector Detail", "url": "/d/defenseclaw-connector-detail?${__url_time_range}&var-connector=${__value.text}", "targetBlank": false}]}]}]}
    },

    {"type": "row", "title": "Hook latency", "gridPos": {"x": 0, "y": 61, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Hook latency p95 by connector",
      "description": "95th percentile hook processing latency in milliseconds, per connector.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 62, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, connector) (rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=~\"$connector\"}[$__rate_interval])))", "legendFormat": "{{connector}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "type": "timeseries",
      "title": "Hook latency p95 by event type",
      "description": "95th percentile hook latency by event type (preToolUse, postToolUse, stop, etc).",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 62, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, event_type) (rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=~\"$connector\"}[$__rate_interval])))", "legendFormat": "{{event_type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },

    {"type": "row", "title": "Recent connector events (Loki)", "gridPos": {"x": 0, "y": 70, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "logs",
      "title": "Connector telemetry log stream",
      "description": "Gateway log records for OTLP ingest events and tool invocations from connectors.",
      "datasource": {"type": "loki", "uid": "defenseclaw-loki"},
      "gridPos": {"x": 0, "y": 71, "w": 24, "h": 12},
      "timeFrom": "15m",
      "targets": [{"expr": "{service_namespace=\"ai-governance\"} | json | __error__=\"\" | event_type=~\"tool_invocation|llm_prompt|llm_response|egress|scan\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true}
    }
  ],
  "preload": false,
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["defenseclaw", "observability", "connectors", "hook"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "DefenseClaw — Hook Connectors",
  "uid": "defenseclaw-connectors",
  "version": 3,
  "weekStart": ""
}
