          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(defenseclaw_http_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
