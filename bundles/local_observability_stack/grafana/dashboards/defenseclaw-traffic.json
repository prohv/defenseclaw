    {
      "type": "table",
      "title": "Top slow routes (p95, 5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by (le, http_route, http_method) (rate(defenseclaw_http_request_duration_milliseconds_bucket[5m]))))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "p95 ms"
            }
          }
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_request_duration_milliseconds \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
