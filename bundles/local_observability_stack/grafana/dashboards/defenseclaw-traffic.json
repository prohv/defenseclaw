    {
      "type": "table",
      "title": "Recent gateway traces",
      "description": "TraceQL search for the defenseclaw service. Click the trace ID cell to open the flame graph in Explore.",
      "datasource": {
        "type": "tempo",
        "uid": "defenseclaw-tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 113,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=",
              "scope": "resource",
              "value": [
                "defenseclaw"
              ],
              "valueType": "string"
            }
          ],
          "limit": 50,
          "tableType": "traces",
          "refId": "A"
        }
