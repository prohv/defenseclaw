  "panels": [
    {
      "type": "row",
      "title": "HTTP surface",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "stat",
      "title": "Requests / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_http_request_count_total[5m])) or vector(0)",
          "refId": "A"
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
    {
      "type": "stat",
      "title": "5xx rate",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "(sum(rate(defenseclaw_http_request_count_total{http_status_code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(defenseclaw_http_request_count_total[5m])), 0.0001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
    {
      "type": "stat",
      "title": "Auth failures / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_http_auth_failures_total[5m])) * 60 or vector(0)",
          "refId": "A"
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_auth_failures \u2192 internal/gateway/router.go"
    },
    {
      "type": "row",
      "title": "HTTP traffic",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
