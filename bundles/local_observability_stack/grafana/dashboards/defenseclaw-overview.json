  "panels": [
    {
      "type": "row",
      "title": "Health KPIs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Firing alerts",
      "description": "Count of Prometheus alerting rules currently firing.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Verdicts / min",
      "description": "Guardrail verdicts emitted per minute across every stage.\n\ncovered_by:\n  - defenseclaw_inspect_evaluations \u2192 internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_inspect_evaluations_total[5m])) * 60 or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Blocks / min",
      "description": "Verdict=block rate. A non-zero value means DefenseClaw is actively denying traffic \u2014 open Security to see which stage and reason.\n\ncovered_by:\n  - defenseclaw_inspect_evaluations \u2192 internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_inspect_evaluations_total{action=\"block\"}[5m])) * 60 or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          },
          "links": [
            {
              "title": "Open Security dashboard",
              "url": "/d/defenseclaw-security?${__url_time_range}&var-action=block"
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Confirm-rate (HITL handoff, 5m)",
      "description": "Share of verdicts that asked the user for explicit confirmation. This is the chat-HILT handoff signal \u2014 every confirm should land as approved/denied/timeout in HITL.\n\ncovered_by:\n  - defenseclaw_inspect_evaluations \u2192 internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_inspect_evaluations_total{action=\"confirm\"}[5m])) / clamp_min(sum(rate(defenseclaw_inspect_evaluations_total[5m])), 0.0001) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          },
          "links": [
            {
              "title": "Open HITL dashboard",
              "url": "/d/defenseclaw-hitl?${__url_time_range}"
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "HITL pending (chat)",
      "description": "Approval requests that haven't yet resolved (approved / denied / timed out) over the last 5 minutes. Sustained > 0 means a user has stalled out \u2014 investigate in HITL.\n\ncovered_by:\n  - defenseclaw_guardrail_evaluations \u2192 internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "clamp_min(sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=\"approval_requested\"}[5m])) - sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=~\"approval_approved|approval_denied|approval_timeout\"}[5m])), 0) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "links": [
            {
              "title": "Open HITL dashboard",
              "url": "/d/defenseclaw-hitl?${__url_time_range}"
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Exporter freshness",
      "description": "Seconds since the OTLP metric exporter last succeeded. Alerts fire if > 300s.\n\ncovered_by:\n  - defenseclaw_telemetry_exporter_last_export_ts_seconds \u2192 internal/telemetry/provider.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "time() - max(defenseclaw_telemetry_exporter_last_export_ts_seconds) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Top blocked rule (1h)",
      "description": "rule_id that fired the most high/critical findings in the last hour. Click to drill into Findings filtered by this rule.\n\ncovered_by:\n  - defenseclaw_scan_findings_by_rule \u2192 internal/telemetry/scan.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "topk(1, sum by (rule_id) (increase(defenseclaw_scan_findings_by_rule_total{severity=~\"high|critical|HIGH|CRITICAL\"}[1h])))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^rule_id$/"
        },
        "colorMode": "background",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open Findings dashboard",
              "url": "/d/defenseclaw-findings?${__url_time_range}&var-severity=HIGH&var-severity=CRITICAL"
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Schema violations / min",
      "description": "Events dropped by the strict JSON-schema gate in gatewaylog.Writer. ANY non-zero value is a contract bug \u2014 check Reliability dashboard.\n\ncovered_by:\n  - defenseclaw_schema_violations \u2192 internal/gatewaylog/writer.go (schema gate)",
