    {
      "type": "row",
      "title": "Firing alerts",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Alerts (Prometheus rules)",
      "description": "All Prometheus alerting rules currently firing, sourced from prometheus/rules/alerts.yml. Click through to the linked dashboards via the navbar above.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true,
              "Value": true
            },
            "indexByName": {
              "alertname": 0,
              "severity": 1,
              "surface": 2,
              "slo": 3,
              "alertstate": 4
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "critical": {
                  "color": "red",
                  "index": 0
                },
                "warning": {
                  "color": "orange",
                  "index": 1
                },
                "info": {
                  "color": "blue",
                  "index": 2
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "SLO compliance",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "Block SLO \u2014 enforcement < 2000 ms (5m)",
      "description": "Fraction of admission-block decisions that complete in <2s. Target \u2265 99%.\n\ncovered_by:\n  - defenseclaw_slo_block_latency_milliseconds \u2192 internal/telemetry/slo.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_slo_block_latency_milliseconds_bucket{le=\"2000\"}[5m])) / sum(rate(defenseclaw_slo_block_latency_milliseconds_count[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      }
    },
    {
      "type": "gauge",
      "title": "Active connectors (5m)",
      "description": "Distinct connectors that emitted hook invocations or OTLP records in the last 5 minutes. Click to open Connectors Overview.\n\ncovered_by:\n  - defenseclaw_connector_hook_invocations \u2192 internal/gateway/hook_telemetry.go\n  - defenseclaw_otel_ingest_records \u2192 internal/gateway/otel_ingest.go",
