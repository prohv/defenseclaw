{
  "annotations": {
    "list": []
  },
  "description": "Scanner operational health: throughput, queue depth, scan duration, errors, quarantine. Rule-level finding analysis (top rules, heat map, target attribution, finding\u2192verdict correlation) lives on the Findings dashboard \u2014 click 'Open findings detail' from any scanner row.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/defenseclaw-overview?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Findings",
      "type": "link",
      "url": "/d/defenseclaw-findings?${__url_time_range}&${scanner:queryparam}&${severity:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Verdicts",
      "type": "link",
      "url": "/d/defenseclaw-security?${__url_time_range}&${severity:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Hook Connectors",
      "type": "link",
      "url": "/d/defenseclaw-connectors?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Reliability",
      "type": "link",
      "url": "/d/defenseclaw-reliability?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "scanner",
        "label": "Scanner",
        "description": "Filter panels by scanner. Defaults to All so panels show 'no data' rather than silently matching the empty string when ingest is empty.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "defenseclaw-prometheus"
        },
        "definition": "label_values(defenseclaw_scan_count_total, scanner)",
        "query": {
          "query": "label_values(defenseclaw_scan_count_total, scanner)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          }
        ],
        "skipUrlSync": false,
        "hide": 0
      },
      {
        "name": "target_type",
        "label": "Target type",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "defenseclaw-prometheus"
        },
        "definition": "label_values(defenseclaw_scan_count_total, target_type)",
        "query": {
          "query": "label_values(defenseclaw_scan_count_total, target_type)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          }
        ],
        "skipUrlSync": false,
        "hide": 0
      },
      {
        "name": "severity",
        "label": "Severity",
        "type": "custom",
        "query": "CRITICAL,HIGH,MEDIUM,LOW,INFO",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "CRITICAL",
            "value": "CRITICAL",
            "selected": false
          },
          {
            "text": "HIGH",
            "value": "HIGH",
            "selected": false
          },
          {
            "text": "MEDIUM",
            "value": "MEDIUM",
            "selected": false
          },
          {
            "text": "LOW",
            "value": "LOW",
            "selected": false
          },
          {
            "text": "INFO",
            "value": "INFO",
            "selected": false
          }
        ],
        "skipUrlSync": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Scanner throughput",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Scans / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_scan_count_total{scanner=~\"$scanner\", target_type=~\"$target_type\"}[5m])) * 60 or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Scanner errors / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_scan_errors_total{scanner=~\"$scanner\", target_type=~\"$target_type\"}[5m])) * 60 or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Open findings (gauge)",
      "description": "defenseclaw.scan.findings.gauge \u2014 up/down counter of live findings.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(defenseclaw_scan_findings_gauge{severity=~\"$severity\"}) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Quarantine actions / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_quarantine_actions_total[5m])) * 60 or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Scan rate + latency",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Scans per scanner (verdict mix)",
      "description": "Verdict here is the per-scan summary verdict (clean | warn | block) \u2014 distinct from the guardrail verdict_action enum used on the Security board.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (scanner, verdict) (rate(defenseclaw_scan_count_total{scanner=~\"$scanner\", target_type=~\"$target_type\"}[$__rate_interval]))",
          "legendFormat": "{{scanner}} \u00b7 {{verdict}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Scan duration p50/p95/p99 (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(defenseclaw_scan_duration_milliseconds_bucket{scanner=~\"$scanner\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(defenseclaw_scan_duration_milliseconds_bucket{scanner=~\"$scanner\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(defenseclaw_scan_duration_milliseconds_bucket{scanner=~\"$scanner\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "type": "heatmap",
      "title": "Scan duration heatmap",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (le) (increase(defenseclaw_scan_duration_milliseconds_bucket{scanner=~\"$scanner\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "ms"
        }
      }
    },
    {
      "type": "row",
      "title": "Findings (operational view \u2014 drill to Findings board for rule analysis)",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Findings by severity",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (severity) (rate(defenseclaw_scan_findings_total{scanner=~\"$scanner\", target_type=~\"$target_type\", severity=~\"$severity\"}[$__rate_interval]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 25
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Findings by scanner",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (scanner) (rate(defenseclaw_scan_findings_total{scanner=~\"$scanner\", target_type=~\"$target_type\", severity=~\"$severity\"}[$__rate_interval]))",
          "legendFormat": "{{scanner}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "row",
      "title": "Quarantine + queue",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Quarantine actions",
      "description": "op \u2208 {move_in, move_out, restore}. A spike in move_in without matching findings usually means a policy regression.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (quarantine_op, quarantine_result) (rate(defenseclaw_quarantine_actions_total[$__rate_interval]))",
          "legendFormat": "{{quarantine_op}} \u00b7 {{quarantine_result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Scanner queue depth",
      "description": "Pending scan jobs per scanner. Sustained growth implies the scanner is slower than ingest.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "defenseclaw_scanner_queue_depth{scanner=~\"$scanner\"}",
          "legendFormat": "{{scanner}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Scanner errors",
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Scanner errors by type",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (scanner, error_type) (rate(defenseclaw_scan_errors_total{scanner=~\"$scanner\"}[$__rate_interval]))",
          "legendFormat": "{{scanner}} \u00b7 {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "table",
      "title": "Drilldown \u2014 open Findings board",
      "description": "Top 10 rules right now (1h). The full ranked Findings dashboard has heatmap + first/last-seen + target attribution. Click a rule_id to drill in with the rule pinned.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 41,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sort_desc(sum by (scanner, rule_id, severity) (increase(defenseclaw_scan_findings_by_rule_total{scanner=~\"$scanner\", severity=~\"$severity\"}[1h]))))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "findings/1h"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "rule_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open Findings detail",
                    "url": "/d/defenseclaw-findings?${__url_time_range}&var-rule_id=${__value.text}&${severity:queryparam}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "preload": false,
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": [
    "defenseclaw",
    "scanners",
    "operations"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "DefenseClaw \u2014 Scanners (Ops)",
  "uid": "defenseclaw-scanners",
  "version": 3,
  "weekStart": ""
}