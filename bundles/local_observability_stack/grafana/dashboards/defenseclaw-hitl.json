    {
      "type": "bargauge",
      "title": "Funnel snapshot (1h totals)",
      "description": "Visual funnel from upstream verdict_action=confirm into chat HILT and exec approval outcomes. The two pipelines are independent \u2014 exec approvals are routed via the WebSocket exec-approval pipeline, chat HILT via the OpenClaw approval manager \u2014 but both originate from a verdict_action=confirm.\n\ncovered_by:\n  - defenseclaw_approval_count \u2192 internal/telemetry/metrics.go:1146 (RecordApproval) \u2014 code-emitted, will populate once exec approvals run\n  - defenseclaw_guardrail_evaluations \u2192 internal/telemetry/metrics.go (RecordGuardrailEvaluation)\n  - defenseclaw_inspect_evaluations \u2192 internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action=\"confirm\"}[1h]))",
          "legendFormat": "1. confirm verdicts",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=\"approval_requested\"}[1h]))",
          "legendFormat": "2a. chat HILT requested",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=\"approval_approved\"}[1h]))",
          "legendFormat": "3a. chat HILT approved",
          "refId": "C",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=\"approval_denied\"}[1h]))",
          "legendFormat": "3b. chat HILT denied",
          "refId": "D",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=\"approval_timeout\"}[1h]))",
          "legendFormat": "3c. chat HILT timeout",
          "refId": "E",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_approval_count_total{result=\"approved\"}[1h]))",
          "legendFormat": "2b. exec approval approved",
          "refId": "F",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_approval_count_total{result=\"denied\"}[1h]))",
          "legendFormat": "2c. exec approval denied",
          "refId": "G",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "orientation": "horizontal"
      }
    },
    {
      "type": "row",
