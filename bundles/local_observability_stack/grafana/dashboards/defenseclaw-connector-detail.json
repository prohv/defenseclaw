{
  "annotations": {"list": []},
  "description": "Per-connector deep-dive driven by the $connector variable. Open from the Connectors overview by clicking any connector name. Panels use source / connector / gen_ai_agent_name labels depending on the underlying metric.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {"title": "Connectors overview", "type": "link", "url": "/d/defenseclaw-connectors?${__url_time_range}",                                                                                       "icon": "external link", "targetBlank": false},
    {"title": "Verdicts",            "type": "link", "url": "/d/defenseclaw-security?${__url_time_range}&${connector:queryparam}&${stage:queryparam}&${action:queryparam}&${severity:queryparam}", "icon": "external link", "targetBlank": false},
    {"title": "HITL",                "type": "link", "url": "/d/defenseclaw-hitl?${__url_time_range}&${connector:queryparam}",                                                                     "icon": "external link", "targetBlank": false},
    {"title": "Findings",            "type": "link", "url": "/d/defenseclaw-findings?${__url_time_range}",                                                                                          "icon": "external link", "targetBlank": false},
    {"title": "Agent identity",      "type": "link", "url": "/d/defenseclaw-agent-identity?${__url_time_range}&${connector:queryparam}",                                                            "icon": "external link", "targetBlank": false},
    {"title": "Overview",            "type": "link", "url": "/d/defenseclaw-overview?${__url_time_range}",                                                                                          "icon": "external link", "targetBlank": false}
  ],
  "templating": {
    "list": [
      {
        "name": "connector",
        "label": "Connector",
        "description": "Connector to deep-dive on. Sourced from defenseclaw_connector_hook_invocations_total{connector} so hook-only connectors (cursor, hermes, copilot, geminicli, windsurf) appear — defenseclaw_otel_ingest_records_total{source} only covers connectors that push native OTLP and would silently exclude every hook-only connector.",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
        "definition": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
        "query": {"query": "label_values(defenseclaw_connector_hook_invocations_total, connector)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {"text": "claudecode", "value": "claudecode", "selected": true},
        "skipUrlSync": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {"type": "row", "title": "Connector $connector — at a glance", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "stat",
      "title": "Activity / min",
      "description": "OTLP records/min when the connector pushes native OTLP, otherwise falls back to hook invocations/min. Hook-only connectors (cursor, hermes, copilot, geminicli, windsurf) populate the second branch.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_otel_ingest_records_total{source=\"$connector\"}[5m])) * 60 or sum(rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Hooks / min",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Tokens / min",
      "description": "OTel GenAI token rate (gen_ai.client.token.usage). Populated only when the connector proxies LLM calls through DefenseClaw (claudecode-bridge, codex-notify, openclaw). Hook-only connectors (cursor, hermes, copilot, geminicli, windsurf) do not see LLM bodies and will read 0 — that is by design.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(gen_ai_client_token_usage_sum{gen_ai_agent_name=\"$connector\"}[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Silence (s)",
      "description": "Seconds since the last accepted OTel batch (native-OTLP connectors) OR the last hook invocation seen for this connector. Hook-only connectors fall back to the hook-rate freshness so the panel is meaningful for cursor/hermes/copilot/geminicli/windsurf. >600s triggers DefenseClawConnectorTelemetrySilent.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "time() - max(defenseclaw_otel_ingest_last_seen_ts_seconds{source=\"$connector\"}) or (time() - timestamp(sum(rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[1m])) > bool 0)) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 60}, {"color": "red", "value": 600}]}}}
    },
    {
      "type": "stat",
      "title": "Hook latency p95 (ms)",
      "description": "95th percentile hook processing latency for this connector.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=\"$connector\"}[5m])) by (le)) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]}}}
    },
    {
      "type": "stat",
      "title": "Evaluations / min",
      "description": "Guardrail evaluations / min for this connector (defenseclaw_inspect_evaluations_total filtered by tool=^$connector:). Replaced the prior 'OTLP requests / min' panel which was always zero for hook-only connectors. Native-OTLP-push counts are still visible in the OTLP ingest row below.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_inspect_evaluations_total{tool=~\"$connector:.*\"}[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },

    {"type": "row", "title": "OTLP ingest (native-push connectors only)", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Records / sec by signal",
      "description": "Empty for hook-only connectors (cursor, hermes, copilot, geminicli, windsurf) — they do not push OTLP, only fire hooks. Native-OTLP connectors (claudecode-bridge, codex-notify, openclaw) populate this panel.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (signal) (rate(defenseclaw_otel_ingest_records_total{source=\"$connector\"}[$__rate_interval]))", "legendFormat": "{{signal}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Bytes / sec by signal",
      "description": "Empty for hook-only connectors. See sibling 'Records / sec by signal' panel.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (signal) (rate(defenseclaw_otel_ingest_bytes_total{source=\"$connector\"}[$__rate_interval]))", "legendFormat": "{{signal}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },

    {"type": "row", "title": "Hooks", "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Hook invocations / sec by event_type x result",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (event_type, result) (rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[$__rate_interval]))", "legendFormat": "{{event_type}} / {{result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Hook latency p95 by event_type",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, event_type) (rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=\"$connector\"}[$__rate_interval])))", "legendFormat": "{{event_type}} p95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },

    {"type": "row", "title": "GenAI tokens + LLM duration (LLM-proxy connectors only)", "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Tokens / sec by direction x model",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (gen_ai_token_type, gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{gen_ai_agent_name=\"$connector\"}[$__rate_interval]))", "legendFormat": "{{gen_ai_request_model}} / {{gen_ai_token_type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "LLM duration p50/p95/p99 (s)",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_agent_name=\"$connector\"}[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_agent_name=\"$connector\"}[$__rate_interval])) by (le))", "legendFormat": "p95", "refId": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_agent_name=\"$connector\"}[$__rate_interval])) by (le))", "legendFormat": "p99", "refId": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },

    {"type": "row", "title": "Verdicts (global)", "gridPos": {"x": 0, "y": 32, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Verdicts by action (stacked)",
      "description": "Verdict action mix: allow / warn / alert / confirm / block.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 33, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total{tool=~\"$connector:.*\"}[$__rate_interval]))", "legendFormat": "{{action}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 20}}}
    },
    {
      "type": "timeseries",
      "title": "Evaluations by hook event",
      "description": "Which hook lifecycle event triggered each guardrail evaluation for this connector.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 33, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (tool) (rate(defenseclaw_inspect_evaluations_total{tool=~\"$connector:.*\"}[$__rate_interval]))", "legendFormat": "{{tool}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}, "fillOpacity": 20}}}
    },

    {"type": "row", "title": "LLM judge", "gridPos": {"x": 0, "y": 41, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Judge invocations by kind",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 42, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (judge_kind) (rate(defenseclaw_gateway_judge_invocations_total[$__rate_interval]))", "legendFormat": "{{judge_kind}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Judge latency p95 by kind",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 42, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, judge_kind) (rate(defenseclaw_gateway_judge_latency_milliseconds_bucket[$__rate_interval])))", "legendFormat": "{{judge_kind}} p95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },

    {"type": "row", "title": "Tools + findings", "gridPos": {"x": 0, "y": 50, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "table",
      "title": "Top tools (1h)",
      "description": "Most-invoked tools in the last hour. dangerous=true rows correlate with exec-approval prompts.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 51, "w": 12, "h": 8},
      "targets": [{"expr": "topk(15, sort_desc(sum by (gen_ai_tool_name, dangerous) (increase(defenseclaw_tool_calls_total[1h]))))", "instant": true, "format": "table", "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true}, "renameByName": {"Value": "calls/1h"}}}]
    },
    {
      "type": "table",
      "title": "Top findings by rule (24h)",
      "description": "Scanner findings aggregated by rule across all scanners.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 51, "w": 12, "h": 8},
      "targets": [{"expr": "topk(20, sort_desc(sum by (scanner, rule_id, severity) (increase(defenseclaw_scan_findings_by_rule_total[24h]))))", "instant": true, "format": "table", "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true}, "renameByName": {"Value": "findings/24h"}}}]
    },

    {"type": "row", "title": "Recent connector events (Loki)", "gridPos": {"x": 0, "y": 59, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "logs",
      "title": "$connector — gateway events",
      "description": "All gateway log events associated with this connector via gen_ai_agent_name or defenseclaw_claw_mode labels.",
      "datasource": {"type": "loki", "uid": "defenseclaw-loki"},
      "gridPos": {"x": 0, "y": 60, "w": 24, "h": 14},
      "timeFrom": "1h",
      "targets": [{"expr": "{service_namespace=\"ai-governance\"} | json | __error__=\"\" | agent_name=\"$connector\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true}
    }
  ],
  "preload": false,
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["defenseclaw", "observability", "connectors", "detail"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "DefenseClaw — Connector Detail",
  "uid": "defenseclaw-connector-detail",
  "version": 2,
  "weekStart": ""
}
